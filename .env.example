# Veriva — env variables šablonas
# Kopijuoti į .env.local (lokaliai) arba pridėti į Vercel project settings (production)
# NIEKADA NEKOMITINTI .env failo su realiomis reikšmėmis

# ─── Supabase ───
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_ANON_KEY=eyJ...

# ─── Resend ───
RESEND_API_KEY=re_xxxxx
RESEND_FROM_EMAIL=hello@veriva.lt
RESEND_NOTIFY_EMAIL=info@veriva.lt

# ─── Webhook auth (atskiri per endpoint, NE shared) ───
CONTACT_FORM_SECRET=generate-with-openssl-rand-hex-32
AUDIT_REQUEST_SECRET=generate-with-openssl-rand-hex-32
HEALTH_CHECK_SECRET=generate-with-openssl-rand-hex-32

# ─── Rate limiting (Upstash Redis, optional) ───
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Analytics (frontend, public) ───
# Šie keliauja į HTML, NE Edge Function
# GA4_MEASUREMENT_ID=G-XXXXXXXXXX
# GTM_ID=GTM-XXXXXXX
