# Veriva — env variables šablonas
# Kopijuoti į .env.local (lokaliai) arba pridėti į Vercel project settings (production)
# NIEKADA NEKOMITINTI .env failo su realiomis reikšmėmis

# ═══ Supabase (shared with Empirra — tables prefixed veriva_*) ═══
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_ANON_KEY=eyJ...

# ═══ Resend ═══
RESEND_API_KEY=re_xxxxx
RESEND_FROM_EMAIL=hello@veriva.lt
RESEND_NOTIFY_EMAIL=info@veriva.lt

# ═══ Form endpoint auth (atskiri per endpoint, NE shared) ═══
CONTACT_FORM_SECRET=generate-with-openssl-rand-hex-32
AUDIT_REQUEST_SECRET=generate-with-openssl-rand-hex-32
HEALTH_CHECK_SECRET=generate-with-openssl-rand-hex-32

# ═══ BDAR audito klausimynas (/bdar-auditas — VIEŠAS endpoint, be x-api-key) ═══
# IP_HASH_SALT — PRIVALOMAS. Be jo IP nesaugomas (data minimization). Generuoti: openssl rand -hex 32
IP_HASH_SALT=generate-with-openssl-rand-hex-32

# ═══ Blog automation pipeline ═══
# AI generation
OPENAI_API_KEY=sk-proj-...

# Hero images
PEXELS_API_KEY=...

# GitHub repo access (riko8825/Veriva-geras)
# Token must have `repo` scope (classic) or contents:write (fine-grained)
GITHUB_TOKEN=ghp_...

# Telegram bot (atskiras nuo Empirra — sukurti per @BotFather)
TELEGRAM_BOT_TOKEN=1234567890:ABC-...
TELEGRAM_CHAT_ID=123456789
# Webhook secret — set as header `X-Telegram-Bot-Api-Secret-Token` in setWebhook call
TELEGRAM_WEBHOOK_SECRET=generate-with-openssl-rand-hex-32

# Blog endpoint auth secrets (atskiri per endpoint)
BLOG_TRIGGER_SECRET=generate-with-openssl-rand-hex-32
BLOG_APPROVE_SECRET=generate-with-openssl-rand-hex-32

# Vercel cron — auto-injected by Vercel platform, but also used for manual trigger header
CRON_SECRET=generate-with-openssl-rand-hex-32

# ═══ Rate limiting (Upstash Redis, optional) ═══
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ═══ Analytics (frontend, public) ═══
# Šie keliauja į HTML, NE Edge Function
# GA4_MEASUREMENT_ID=G-XXXXXXXXXX
# GTM_ID=GTM-XXXXXXX

# ═══ Feature flags (debug only) ═══
# DISABLE_AI=true        — AI generation off (blog-gen returns mock)
# DISABLE_TELEGRAM=true  — Telegram notifications off
