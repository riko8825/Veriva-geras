{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "outputDirectory": ".",
  "cleanUrls": true,
  "trailingSlash": false,
  "builds": [
    { "src": "api/forms/contact.ts",                       "use": "@vercel/node", "config": { "maxDuration": 30 } },
    { "src": "api/forms/audit-request.ts",                 "use": "@vercel/node", "config": { "maxDuration": 30 } },
    { "src": "api/internal/health.ts",                     "use": "@vercel/node", "config": { "maxDuration": 10 } },
    { "src": "api/automations/blog-gen/route.ts",          "use": "@vercel/node", "config": { "maxDuration": 90 } },
    { "src": "api/automations/blog-approve/route.ts",      "use": "@vercel/node", "config": { "maxDuration": 60 } },
    { "src": "api/automations/telegram-webhook/route.ts",  "use": "@vercel/node", "config": { "maxDuration": 60 } },
    { "src": "*.html",                                     "use": "@vercel/static" },
    { "src": "blog/*.html",                                "use": "@vercel/static" },
    { "src": "seo/**/index.html",                          "use": "@vercel/static" },
    { "src": "seo/**/*.webp",                              "use": "@vercel/static" },
    { "src": "assets/**",                                  "use": "@vercel/static" },
    { "src": "robots.txt",                                 "use": "@vercel/static" },
    { "src": "sitemap.xml",                                "use": "@vercel/static" },
    { "src": "favicon.ico",                                "use": "@vercel/static" }
  ],
  "rewrites": [
    { "source": "/api/automations/blog-gen",         "destination": "/api/automations/blog-gen/route.ts" },
    { "source": "/api/automations/blog-approve",     "destination": "/api/automations/blog-approve/route.ts" },
    { "source": "/api/automations/telegram-webhook", "destination": "/api/automations/telegram-webhook/route.ts" }
  ],
  "crons": [
    { "path": "/api/automations/blog-gen", "schedule": "0 8 * * 2,4" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ],
  "redirects": [
    { "source": "/index", "destination": "/", "permanent": true },
    { "source": "/index.html", "destination": "/", "permanent": true },
    { "source": "/brief.html", "destination": "/brief", "permanent": true },
    { "source": "/blog.html", "destination": "/blog", "permanent": true },
    { "source": "/slapukai.html", "destination": "/slapukai", "permanent": true },
    { "source": "/privatumas.html", "destination": "/privatumas", "permanent": true },
    { "source": "/paslaugos.html", "destination": "/paslaugos", "permanent": true },
    { "source": "/apie.html", "destination": "/apie", "permanent": true },
    { "source": "/kainos.html", "destination": "/kainos", "permanent": true },
    { "source": "/kontaktai.html", "destination": "/kontaktai", "permanent": true },

    { "source": "/wp-login.php", "destination": "/", "permanent": true },
    { "source": "/wp-admin/:path*", "destination": "/", "permanent": true },
    { "source": "/wp-json/:path*", "destination": "/", "permanent": true },
    { "source": "/wp-includes/:path*", "destination": "/", "permanent": true },
    { "source": "/wp-content/:path*", "destination": "/", "permanent": true },

    { "source": "/privatumo-politika", "destination": "/privatumas", "permanent": true },
    { "source": "/privatumo-politika/", "destination": "/privatumas", "permanent": true },
    { "source": "/pagrindinis", "destination": "/", "permanent": true },
    { "source": "/pagrindinis/", "destination": "/", "permanent": true },
    { "source": "/kibernetinis-saugumas", "destination": "/", "permanent": true },
    { "source": "/kibernetinis-saugumas/", "destination": "/", "permanent": true },
    { "source": "/kontaktai/", "destination": "/", "permanent": true },
    { "source": "/mokymai", "destination": "/", "permanent": true },
    { "source": "/mokymai/", "destination": "/", "permanent": true }
  ]
}
